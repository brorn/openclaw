# Nome da instancia (opcional)
# INSTANCE_NAME=OpenClaw

# --- Telegram (opcional) ---
# Para ativar o Telegram, defina as duas variaveis abaixo:
#   1. Token do bot (via Docker secret ou env var):
#      echo "SEU_TOKEN" > secrets/telegram_bot_token   (recomendado)
#      TELEGRAM_BOT_TOKEN=123456:ABC-DEF               (fallback, menos seguro)
#   2. User IDs permitidos, separados por virgula (descubra em @userinfobot):
# ALLOWED_TELEGRAM_USERS=123456789
